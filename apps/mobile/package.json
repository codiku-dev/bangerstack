{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "expo": {
    "install": {
      "exclude": ["@types/react"]
    }
  },
  "scripts": {
    "dotenvx": "node ./node_modules/@dotenvx/dotenvx/src/cli/dotenvx.js",
    "dev": "node ./node_modules/@dotenvx/dotenvx/src/cli/dotenvx.js run -f .env.local.development -- expo start",
    "start": "node ./node_modules/@dotenvx/dotenvx/src/cli/dotenvx.js run -f .env.local.development -- expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "node ./node_modules/@dotenvx/dotenvx/src/cli/dotenvx.js run -f .env.local.development -- expo start --android",
    "ios": "node ./node_modules/@dotenvx/dotenvx/src/cli/dotenvx.js run -f .env.local.development -- expo start --ios",
    "web": "node ./node_modules/@dotenvx/dotenvx/src/cli/dotenvx.js run -f .env.local.development -- expo start --web",
    "lint": "node ./node_modules/@dotenvx/dotenvx/src/cli/dotenvx.js run -f .env.production -- expo lint",
    "check-types": "node ./node_modules/typescript/lib/tsc.js --noEmit",
    "check-env:watch": "cd ../.. && bun run check-env:watch"
  },
  "dependencies": {
    "@repo/trpc": "*",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.0.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.90.19",
    "@trpc/client": "11.8.1",
    "@trpc/react-query": "11.8.1",
    "@trpc/server": "11.8.1",
    "better-auth": "1.4.18",
    "expo": "~54.0.0",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^5.0.0-preview.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.56.4",
    "react-native": "0.81.5",
    "react-native-css": "^3.0.6",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "3.25.5"
  },
  "devDependencies": {
    "reactotron-react-native": "^5.1.18",
    "@dotenvx/dotenvx": "^1.52.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "~19.1.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "lightningcss": "1.30.1"
  }
}
