{
  "name": "mobile",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dotenvx": "dotenvx",
    "dev": "npx turbo run build --filter=@repo/emails && concurrently -n styles,components,check,next --kill-others-on-fail \"npx turbo run dev:styles --filter=@repo/ui\" \"npx turbo run dev:components --filter=@repo/ui\" \"npm run check-env:watch\" \"npm run dev:web\"",
    "dev:web": "npx dotenvx run -f .env.local.development -- next dev --port 3001",
    "dev:emulator": "npx dotenvx run -f .env.local.development -- npm run cap run --live-reload --port 3001",
    "check-env:watch": "cd ../.. && npm run check-env:watch",
    "build": "npx dotenvx run -f .env.production -- next build --webpack",
    "postbuild": "npx @capacitor/cli copy",
    "start": "npx --yes serve@14 out -l 3001",
    "start:prod": "npx --yes serve@14 out -l 3001",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "cap": "capacitor",
    "cap:sync": "npx @capacitor/cli sync",
    "cap:copy": "npx @capacitor/cli copy"
  },
  "dependencies": {
    "@capacitor/android": "8.3.0",
    "@capacitor/cli": "8.3.0",
    "@capacitor/core": "8.3.0",
    "@hookform/resolvers": "^5.0.0",
    "@radix-ui/react-slot": "^1.2.2",
    "@repo/emails": "*",
    "@repo/trpc": "*",
    "@repo/ui": "*",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "16.1.4",
    "next-intl": "4.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.56.4",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.5"
  },
  "devDependencies": {
    "@ionic/cli": "7.2.1",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.19",
    "@trpc/react-query": "11.8.1",
    "@types/node": "25.0.9",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "dotenv": "^16.4.7",
    "eslint": "^9.39.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  }
}