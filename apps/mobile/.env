# Copie vers `.env` pour le dev local (Expo charge automatiquement les `EXPO_PUBLIC_*`).
#
# API Nest (`apps/api`, port par défaut 3090). Simulateur iOS : 127.0.0.1 OK.
# Émulateur Android : souvent http://10.0.2.2:3090 — appareil physique : IP LAN de ta machine.
EXPO_PUBLIC_API_BASE_URL="http://127.0.0.1:3090"

# Optionnel (callback OAuth web ; mobile email/password fonctionne sans)
# EXPO_PUBLIC_GOOGLE_AUTH_CALLBACK_URL=https://example.com/api/auth/callback
