# PORT via env (not CLI `--port`) — Turbopack HMR can mis-resolve the websocket with the flag
PORT=3001

NEXT_PUBLIC_API_BASE_URL=http://localhost:3090
NEXT_PUBLIC_GOOGLE_AUTH_CALLBACK_URL=http://localhost:3000

# Capacitor live reload: emulator → host via 10.0.2.2. Physical device → http://<your-PC-LAN-IP>:3001
CAP_SERVER_URL=http://10.0.2.2:3001
